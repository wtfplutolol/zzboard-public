# ── Time greeting ──────────────────────────────────────────────────────────────
def time_greeting():
    h = datetime.now().hour
    if 5  <= h < 12: return "good morning"
    if 12 <= h < 17: return "good afternoon"
    if 17 <= h < 21: return "good evening"
    return "good night"

