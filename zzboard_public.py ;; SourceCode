def dim_color(hex_color):
    try:
        h = hex_color.lstrip("#")
        r,g,b = int(h[0:2],16),int(h[2:4],16),int(h[4:6],16)
        r,g,b = int(r*0.6),int(g*0.6),int(b*0.6)
        return f"#{r:02x}{g:02x}{b:02x}"
    except Exception:
        return hex_color

