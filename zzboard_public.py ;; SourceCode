# ── Speed test — fixed ─────────────────────────────────────────────────────────
def run_speed_test():
    if speed_cache["running"]: return
    speed_cache["running"] = True
    speed_cache["testing"] = True
    speed_cache["error"]   = None
    try:
        import subprocess as sp
        # Use speedtest-cli via subprocess — most reliable in exe context
        result = sp.run(
            ["speedtest-cli", "--json"],
            capture_output=True, text=True, timeout=120
        )
        if result.returncode == 0:
            data = json.loads(result.stdout)
            speed_cache["download"] = data["download"] / 1_000_000
            speed_cache["upload"]   = data["upload"]   / 1_000_000
            speed_cache["ping"]     = data["ping"]
            speed_cache["last"]     = time.time()
        else:
            # Fallback to speedtest library
            try:
                import speedtest as stlib
                st = stlib.Speedtest()
                st.get_best_server()
                speed_cache["ping"]     = st.results.ping
                st.download(); speed_cache["download"] = st.results.download / 1_000_000
                st.upload();   speed_cache["upload"]   = st.results.upload   / 1_000_000
                speed_cache["last"] = time.time()
            except Exception as e2:
                speed_cache["error"] = str(e2)[:40]
    except FileNotFoundError:
        # speedtest-cli not in PATH, use library directly
        try:
            import speedtest as stlib
            st = stlib.Speedtest()
            st.get_best_server()
            speed_cache["ping"]     = st.results.ping
            st.download(); speed_cache["download"] = st.results.download / 1_000_000
            st.upload();   speed_cache["upload"]   = st.results.upload   / 1_000_000
            speed_cache["last"] = time.time()
        except Exception as e3:
            speed_cache["error"] = str(e3)[:40]
    except Exception as e:
        speed_cache["error"] = str(e)[:40]
    finally:
        speed_cache["testing"] = False
        speed_cache["running"] = False

def fetch_speed():
    run_speed_test()
    while True:
        mins = _cfg_ref.get("speed_interval", 30)
        if mins == 0:
            time.sleep(60); continue
        time.sleep(mins * 60)
        run_speed_test()

