    elif tab == 4:
        if speed_cache["download"]:
            txt=f"Down: {speed_cache['download']:.1f} Mbps | Up: {speed_cache['upload']:.1f} Mbps | Ping: {speed_cache['ping']:.0f}ms"
        else: txt="Speed test not run yet"
    else:
