# ── Key reader ─────────────────────────────────────────────────────────────────
def key_reader():
    try:
        import msvcrt
        while True:
            if msvcrt.kbhit():
                ch = msvcrt.getwch()
                last_key_time["t"] = time.time()
                screensaver_on["v"] = False
                if ch in ("\x00", "\xe0"):
                    ch2 = msvcrt.getwch()
                    with key_lock:
                        key_queue.append(("arrow", ch2))
                else:
                    with key_lock:
                        key_queue.append(("char", ch.lower()))
            time.sleep(0.02)
    except Exception:
        pass

def get_keys():
    with key_lock:
        keys = list(key_queue)
        key_queue.clear()
    return keys

